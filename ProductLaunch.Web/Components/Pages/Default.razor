@namespace ProductLaunch.Web.Components.Pages.Default

@page "/"
@page "/Default"

@using Microsoft.Extensions.Logging
@inject ILogger<Default> Logger

<PageTitle>Home &mdash; ProductLaunch</PageTitle>

<div class="p-5 mb-4 bg-dark text-white rounded-3">
    <div class="container-fluid py-3">
        <h1 class="display-5 fw-bold">We&#39;re launching a new course!</h1>
        <p class="col-md-8 fs-5 text-secondary">The new course by School of Devops is a step-by-step Devops Mastery program.</p>
        <NavLink class="btn btn-primary btn-lg" href="/SignUp">Sign Up Now &raquo;</NavLink>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
                <h2 class="card-title">What&#39;s this application about?</h2>
                <p class="text-muted">
                    If you see this page, congratulations! You have successfully deployed an ASP .NET application
                    running with SQL Server in the backend.
                </p>
                <p class="text-muted">
                    This is a sample legacy application modernised for DevOps practices such as containerisation,
                    continuous integration and delivery with Docker, Kubernetes and Azure.
                </p>
                <a class="btn btn-outline-primary" href="https://www.schoolofdevops.com" target="_blank">
                    Check Out Our Complete Course Portfolio &raquo;
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm bg-primary text-white">
            <div class="card-body p-4 d-flex flex-column justify-content-between">
                <div>
                    <h2 class="card-title">Interested?</h2>
                    <p>Give us your details and we&#39;ll keep you posted.</p>
                    <p>It only takes 30 seconds to sign up.</p>
                </div>
                <NavLink class="btn btn-light fw-semibold mt-3" href="/SignUp">Sign Up &raquo;</NavLink>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        Logger.LogInformation("Default page loaded.");
    }
}
