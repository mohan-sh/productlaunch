@page "/Login"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Microsoft.Extensions.Logging
@using ProductLaunch.Model
@using System.Linq
@inject ProtectedSessionStorage ProtectedSessionStore
@inject NavigationManager Navigation
@inject ILogger<Login> Logger

<PageTitle>Admin Login &mdash; ProductLaunch</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height:70vh;">
    <div class="card shadow border-0" style="width:100%; max-width:420px;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <span style="font-size:2rem; color:#0d6efd;">&#9670;</span>
                <h4 class="mt-2 fw-bold">Admin Portal</h4>
                <p class="text-muted small">Sign in to manage prospects</p>
            </div>

            <EditForm Model="@loginModel" OnValidSubmit="btnLogin_Click" FormName="LoginForm">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Username</label>
                    <InputText @bind-Value="loginModel.Username" class="form-control" placeholder="Enter username" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Password</label>
                    <InputText @bind-Value="loginModel.Password" class="form-control" type="password" placeholder="Enter password" />
                </div>
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2 small">@errorMessage</div>
                }
                <button type="submit" class="btn btn-primary w-100 mt-2">Sign In</button>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new LoginModel();
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await ProtectedSessionStore.GetAsync<string>("AdminUser");
            if (result.Success && !string.IsNullOrEmpty(result.Value))
                Navigation.NavigateTo("/Dashboard");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error checking session on Login page initialization.");
        }
    }

    private async Task btnLogin_Click()
    {
        var username = loginModel.Username?.Trim();
        var password = loginModel.Password;
        try
        {
            using (var db = new ProductLaunchContext())
            {
                var admin = db.AdminUsers
                    .FirstOrDefault(a => a.Username == username && a.Password == password);

                if (admin != null)
                {
                    await ProtectedSessionStore.SetAsync("AdminUser", admin.Username);
                    Navigation.NavigateTo("/Dashboard");
                }
                else
                {
                    errorMessage = "Invalid username or password.";
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during login attempt for user: {Username}", username);
            errorMessage = "An error occurred during login. Please try again.";
        }
    }

    public class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
