{
  // Connection string migrated from Web.config <connectionStrings>.
  // The named connection string "ProductLaunchDb" matches the EF6
  // ProductLaunchContext constructor: base("ProductLaunchDb").
  // Update the value below to match your SQL Server instance.
  "ConnectionStrings": {
    "ProductLaunchDb": "Server=localhost\\SQLEXPRESS;Database=ProductLaunch;Trusted_Connection=True;MultipleActiveResultSets=True;"
  },

  // Logging configuration (replaces system.diagnostics / trace in Web.config).
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },

  // Equivalent to <httpRuntime> allowedHosts restriction in Web.config.
  "AllowedHosts": "*"
}